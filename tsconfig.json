{
  "compilerOptions": {
    "target"          : "ES2019",
    "module"          : "CommonJS",
    "lib"             : ["ES2019"],
    "types"           : ["node"],
    "strict"          : true,
    "esModuleInterop" : true,
    "declaration"     : true,
    "declarationMap"  : true,
    "outDir"          : "./dist",
    "rootDir"         : "./src",
    "skipLibCheck"    : true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
